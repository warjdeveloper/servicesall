---
// astro
import { getCollection } from 'astro:content';
// third
// own
// code
const products = await getCollection('products');
---
<div class="px-4">
    <input
        id="search"
        type="text"
        placeholder="Buscar producto..."
        class="w-full px-4 py-2 mt-3 rounded-xl border border-gray-300 focus:outline-none focus:ring-2 focus:ring-blue-500"
    />
    <h2 class="mt-1 text-bold text-2xl">Filters...</h2>
    <div id="categories" class="flex gap-3 mt-2 overflow-x-auto whitespace-nowrap px-2 scrollbar-hide">
        {
            [...new Set(products.map(p => p.data.category))].map(category => (
                <button class="px-4 py-1 text-black bg-gray-100 hover:bg-blue-500 hover:text-white rounded-full transition">
                    {category}
                </button>
            ))
        }
    </div>
</div>